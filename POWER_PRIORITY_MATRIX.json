    "critical_decision_rules": {
      "rule_1_pawn_promotion_threat": {
        "description": "Opponent pawn on 7th rank = HIGHEST PRIORITY",
        "action": "FROST or VENGEANCE to stop pawn",
        "priority_override": "+750 bonus",
        "exceptions": "None - always respond to 7th rank pawn"
      },
      "rule_2_aether_cap": {
        "description": "At 30/30 aether = generation active",
        "action": "MUST SPEND power each turn or lose 3 aether/turn",
        "priority_override": "Any power >= 20 aether cost is automatic cast",
        "exceptions": "Save 20 aether only if opponent King has 1-2 escape (Chronobreak ready)"
      },
      "rule_3_checkmate_threat": {
        "description": "If opponent threatens mate in 1-2 moves",
        "action": "Defensive power (Fortify/Cleanse/Wall/Blink/Chronobreak)",
        "priority_override": "Ignore offensive opportunities, defend immediately",
        "exceptions": "If your move delivers mate, do that instead"
      },
      "rule_4_vengeance_trap": {
        "description": "Before promoting, check opponent aether >= 18",
        "action": "If opponent 18+ aether AND own Queen undefended: DON'T promote",
        "priority_override": "FORTIFY Queen after promoting (chain powers)",
        "exceptions": "If promotion delivers checkmate, ignore Vengeance threat"
      },
      "rule_5_fountain_control": {
        "description": "Each fountain = +2 aether/turn (stacks with base +2)",
        "action": "Contest 50% of fountains to prevent opponent acceleration",
        "priority_override": "+100 priority if contested fountain at stake",
        "exceptions": "Yield if sacrifice >200 material to take fountain"
      },
      "rule_6_material_balance": {
        "description": "Track material delta (yours - opponent's)",
        "action": "If down 200+: Aggressive powers (Vengeance/Imprison); If up 200+: Consolidate",
        "priority_override": "Desperation multiplier ×1.5 if down material",
        "exceptions": "Checkmate threats override material balance"
      },
      "rule_7_adjacent_imprison": {
        "description": "Own piece adjacent to opponent piece = IMPRISON opportunity",
        "action": "If target is Queen/Rook: CAST IMPRISON (ROI 35-64x)",
        "priority_override": "+100 priority per high-value adjacent piece",
        "exceptions": "Skip if opponent piece defended 2x+ (imprisonment fails)"
      },
      "rule_8_double_attack_clustering": {
        "description": "2+ undefended opponent pieces in reach = DOUBLE_ATTACK opportunity",
        "action": "CAST DOUBLE_ATTACK (ROI 20-40x)",
        "priority_override": "+80 priority per additional undefended piece",
        "exceptions": "Skip if 1st capture defended (recapture = material loss)"
      },
      "rule_9_shield_breach": {
        "description": "Opponent Queen shielded = shield blocks 1 attack",
        "action": "Use DOUBLE_ATTACK to breach (1st hit absorbs shield, 2nd hits Queen)",
        "priority_override": "+50 priority if can breach + capture",
        "exceptions": "Skip if Queen defended after shield breaks"
      },
      "rule_10_aether_reserves": {
        "description": "Maintain 14+ aether buffer for emergency defense",
        "action": "Never drop below 14 aether if opponent has powers available",
        "priority_override": "Reduce offensive priority if reserves <14",
        "exceptions": "At cap (30): Spend liberally, reserves always regenerate"
      }
    },
    "bot_implementation_pseudocode": {
      "priority_calculation_function": {
        "input": ["current_board_state", "my_aether", "opponent_aether", "game_phase", "material_delta"],
        "output": "priority_scores for all 13 powers",
        "algorithm": "For each power: calculate base_priority, apply phase_multiplier, apply material_multiplier, apply threat_multiplier, add bonuses/penalties"
      },
      "pseudo_code": [
        "function calculatePriorityScores(state, myColor) {",
        "  const allPowers = [FROST, FORTIFY, SPAWN, BLINK, IMPRISON, AETHER_BLOCK, CLEANSE, BOMBA, DOUBLE_ATTACK, PROMOTE, VENGEANCE, WALL, CHRONOBREAK];",
        "  const priorities = {};",
        "  ",
        "  for (const power of allPowers) {",
        "    if (state.mana[myColor] < power.cost) {",
        "      priorities[power] = 0; // Can't afford",
        "      continue;",
        "    }",
        "    ",
        "    // Calculate base priority based on power type",
        "    let basePriority = 0;",
        "    switch(power) {",
        "      case FROST:",
        "        basePriority = evaluateFrostTargets(state, myColor);",
        "        break;",
        "      case IMPRISON:",
        "        basePriority = evaluateImprisonTargets(state, myColor);",
        "        break;",
        "      case DOUBLE_ATTACK:",
        "        basePriority = evaluateDoubleAttackSequences(state, myColor);",
        "        break;",
        "      case PROMOTE:",
        "        basePriority = evaluatePromotionSequences(state, myColor);",
        "        break;",
        "      case VENGEANCE:",
        "        basePriority = evaluateVengeanceTargets(state, myColor);",
        "        break;",
        "      // ... other powers",
        "    }",
        "    ",
        "    // Apply multipliers based on game state",
        "    const phaseMultiplier = calculatePhaseMultiplier(state.turnNumber);",
        "    const materialMultiplier = calculateMaterialMultiplier(state, myColor);",
        "    const threatMultiplier = calculateThreatMultiplier(state, myColor);",
        "    ",
        "    const finalPriority = basePriority * phaseMultiplier * materialMultiplier * threatMultiplier;",
        "    priorities[power] = finalPriority;",
        "  }",
        "  ",
        "  return priorities;",
        "}"
      ]
    },
