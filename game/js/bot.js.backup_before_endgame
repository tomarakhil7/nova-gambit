          if (oppMoves.length === 0) hasMateOrNearMate = true; // actual checkmate!
        }
        restore(state.board, snap);
        if (hasMateOrNearMate) break;
      }
      if (hasMateOrNearMate) {
        blockPrio = 200; // TOP PRIORITY: block to deliver checkmate
