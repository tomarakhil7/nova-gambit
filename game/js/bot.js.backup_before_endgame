          if (phase < 0.6) {
            const distToPromo = Math.abs(nr - promoRank);
            score += (7 - distToPromo) * 3;
          }
        }
      }

      return { score: score + emptyCount * 10, count: emptyCount };
    }

    // Strategy 1: Wall near king when under pressure (not just in check)
