# ============================================================
# NOVA GAMBIT - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# The server reads these at startup. Without them, authentication
# (signup/login) is disabled and the game runs in anonymous-only mode.
# ============================================================

# ---------- PostgreSQL (required for accounts & game history) ----------
# The server uses the "pg" npm package and requires a PostgreSQL database.
# There is NO SQLite fallback -- Postgres is strictly required for auth.
#
# Local dev with Docker:
#   docker run -d --name novagambit-pg -p 5432:5432 \
#     -e POSTGRES_USER=nova -e POSTGRES_PASSWORD=nova -e POSTGRES_DB=novagambit \
#     postgres:16
#
# Then use:
DATABASE_URL=postgresql://nova:nova@localhost:5432/novagambit

# Set to "disable" if your local Postgres does NOT use TLS (typical for local dev).
# Railway/production should leave this unset (TLS is required there).
PGSSLMODE=disable

# ---------- JWT Secret (required for accounts) ----------
# Used to sign and verify authentication tokens. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-change-me-at-least-32-chars-long

# ---------- Server (optional) ----------
# PORT defaults to 8765 if unset.
# PORT=8765
# HOST defaults to 0.0.0.0 (all interfaces).
# HOST=0.0.0.0
